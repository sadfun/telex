{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExternalAgentConfigImportHistoriesReadResponse",
  "type": "object",
  "required": [
    "connectors",
    "data"
  ],
  "properties": {
    "connectors": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ExternalAgentImportedConnectorCandidate"
      }
    },
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ExternalAgentConfigImportHistory"
      }
    }
  },
  "definitions": {
    "ExternalAgentConfigImportHistory": {
      "type": "object",
      "required": [
        "completedAtMs",
        "failures",
        "importId",
        "successes"
      ],
      "properties": {
        "completedAtMs": {
          "type": "integer",
          "format": "int64"
        },
        "failures": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalAgentConfigImportItemTypeFailure"
          }
        },
        "importId": {
          "type": "string"
        },
        "successes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalAgentConfigImportItemTypeSuccess"
          }
        }
      }
    },
    "ExternalAgentConfigImportItemTypeFailure": {
      "type": "object",
      "required": [
        "failureStage",
        "itemType",
        "message"
      ],
      "properties": {
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "errorType": {
          "type": [
            "string",
            "null"
          ]
        },
        "failureStage": {
          "type": "string"
        },
        "itemType": {
          "$ref": "#/definitions/ExternalAgentConfigMigrationItemType"
        },
        "message": {
          "type": "string"
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "subErrorType": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ExternalAgentConfigImportItemTypeSuccess": {
      "type": "object",
      "required": [
        "itemType"
      ],
      "properties": {
        "cwd": {
          "type": [
            "string",
            "null"
          ]
        },
        "itemType": {
          "$ref": "#/definitions/ExternalAgentConfigMigrationItemType"
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "target": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "ExternalAgentConfigMigrationItemType": {
      "type": "string",
      "enum": [
        "AGENTS_MD",
        "CONFIG",
        "SKILLS",
        "PLUGINS",
        "MCP_SERVER_CONFIG",
        "SUBAGENTS",
        "HOOKS",
        "COMMANDS",
        "MEMORY",
        "SESSIONS"
      ]
    },
    "ExternalAgentImportedConnectorCandidate": {
      "type": "object",
      "required": [
        "name",
        "sessionCount",
        "source"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "sessionCount": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "source": {
          "$ref": "#/definitions/ExternalAgentImportedConnectorSource"
        }
      }
    },
    "ExternalAgentImportedConnectorSource": {
      "type": "string",
      "enum": [
        "remoteMcpServersConfig"
      ]
    }
  }
}