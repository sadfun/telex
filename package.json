{
  "name": "telex",
  "version": "0.0.3",
  "private": true,
  "type": "module",
  "description": "Telex — a Telegram bridge for the OpenAI Codex app-server.",
  "license": "FSL-1.1-MIT",
  "homepage": "https://github.com/sadfun/telex#readme",
  "bugs": {
    "url": "https://github.com/sadfun/telex/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sadfun/telex.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "telex": "./dist/cli/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/cli/copy-assets.js",
    "check": "tsc -p tsconfig.test.json && biome check .",
    "dev": "npm run build && node --env-file-if-exists=.env --watch dist/index.js",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "protocol:generate-bindings": "node --import tsx src/cli/generate-protocol-bindings.ts",
    "codex:check": "node --import tsx src/cli/main.ts codex check",
    "codex:update": "node --import tsx src/cli/main.ts codex check --apply"
  },
  "dependencies": {
    "@grammyjs/runner": "^2.0.3",
    "@telegram-apps/telegram-ui": "2.1.13",
    "grammy": "^1.45.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^24.13.3",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "esbuild": "^0.25.10",
    "tsx": "^4.20.6",
    "typescript": "7.0.2",
    "vitest": "^4.1.10"
  }
}
